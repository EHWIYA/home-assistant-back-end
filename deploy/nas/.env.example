# NAS /home/iwh/iot/api/.env — 값은 서버에서만 입력 (커밋 금지)

HA_BASE_URL=http://host.docker.internal:8123
HA_TOKEN=
IOT_API_KEY=
PORT=8002
# Docker: 반드시 0.0.0.0 (127.0.0.1 이면 호스트 curl /health 실패 가능)
HOST=0.0.0.0
AC_POWER_THRESHOLD_W=50
CORS_ORIGINS=https://iot.iwhya.kr
LOG_LEVEL=info
HA_TIMEOUT_SECONDS=10

# Hejhome PowerStrip2 + PostgreSQL (NAS /home/iwh/iot/api/.env)
DATABASE_URL=postgresql+asyncpg://iot_user:CHANGE_ME@127.0.0.1:5433/iot_db
HEJHOME_EMAIL=
HEJHOME_PASSWORD=
HEJHOME_STRIP_ID=
HEJHOME_FAMILY_ID=
HEJHOME_BASE_URL=https://square.hej.so
HEJHOME_TIMEOUT_SECONDS=15
STRIP_CHANNEL_COUNT=4
